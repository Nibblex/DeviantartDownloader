# DeviantArt API credentials
# Get them by registering an application at:
#   https://www.deviantart.com/developers/register
# and then copying them from https://www.deviantart.com/developers/apps
#
# Copy this file as ".env" and fill in the values:
#   cp .env.example .env

DA_CLIENT_ID=your_client_id
DA_CLIENT_SECRET=your_client_secret

# Simultaneous website downloads (optional, default: 4, recommended not to
# exceed 8). The website route costs no API quota. Overridden with -w/--web-workers.
DA_WEB_WORKERS=4

# Simultaneous API downloads (optional, default: 2). Kept low on purpose: the
# API is rate-limited, so fewer parallel requests avoid 429s. Overridden with
# --api-workers.
DA_API_WORKERS=2

# Pause in seconds after each API download, per thread (optional, default: 0.5).
# Throttles the API route only; website downloads cost no quota and are never
# delayed. Can be overridden on the command line with --delay.
DA_DELAY=0.5

# Strip the blur filter the API applies to mature-content previews
# (optional, default: false, images are kept as the API serves them).
# Can also be enabled on the command line with --unblur.
DA_UNBLUR=false

# File format for literature and journals, which have no media file
# (optional, default: txt). "txt" saves the plain text; "html" saves a
# standalone HTML document that keeps the formatting. Same as
# --literature-format on the command line.
DA_LITERATURE_FORMAT=txt

# Route every work through the API instead of reading the website's public
# listing (optional, default: false). The website route costs no API quota;
# turn this on only if it breaks. Same as --api-only on the command line.
DA_API_ONLY=false

# Output folder (optional, default: "downloads" relative to the current
# directory). Accepts absolute or relative paths, and "~" is expanded.
# Can be overridden on the command line with -o/--output.
# Files are saved to <output>/<username>/web/ or <output>/<username>/api/,
# depending on which route each work took.
DA_OUTPUT=~/Pictures/deviantart
