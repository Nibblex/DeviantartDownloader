# DeviantArt API credentials
# Get them by registering an application at:
#   https://www.deviantart.com/developers/register
# and then copying them from https://www.deviantart.com/developers/apps
#
# Copy this file as ".env" and fill in the values:
#   cp .env.example .env

DA_CLIENT_ID=your_client_id
DA_CLIENT_SECRET=your_client_secret

# Simultaneous downloads (optional, default: 4, recommended not to exceed 8).
# Can be overridden on the command line with -w/--workers.
DA_WORKERS=4

# Strip the blur filter the API applies to mature-content previews
# (optional, default: false, images are kept as the API serves them).
# Can also be enabled on the command line with --unblur.
DA_UNBLUR=false

# Output folder (optional, default: "downloads" relative to the current
# directory). Accepts absolute or relative paths, and "~" is expanded.
# Can be overridden on the command line with -o/--output.
# Files are saved to <output>/<username>/.
DA_OUTPUT=~/Pictures/deviantart
