# Credenciales de la API de DeviantArt
# Obtenlas registrando una aplicación en:
#   https://www.deviantart.com/developers/register
# y luego copiándolas desde https://www.deviantart.com/developers/apps
#
# Copia este archivo como ".env" y rellena los valores:
#   cp .env.example .env

DA_CLIENT_ID=tu_client_id
DA_CLIENT_SECRET=tu_client_secret

# Descargas simultáneas (opcional, default: 4, recomendado no superar 8).
# Se puede sobrescribir por línea de comandos con -w/--workers.
DA_WORKERS=4
