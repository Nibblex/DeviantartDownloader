# DeviantArt API credentials
# Get them by registering an application at:
#   https://www.deviantart.com/developers/register
# and then copying them from https://www.deviantart.com/developers/apps
#
# Copy this file as ".env" and fill in the values:
#   cp .env.example .env

DA_CLIENT_ID=your_client_id
DA_CLIENT_SECRET=your_client_secret

# Simultaneous downloads (optional, default: 4, recommended not to exceed 8).
# Can be overridden on the command line with -w/--workers.
DA_WORKERS=4
